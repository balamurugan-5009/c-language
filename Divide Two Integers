#include <limits.h>

int divide(int dividend, int divisor)
{
    if (dividend == INT_MIN && divisor == -1)
        return INT_MAX;

    long long dvd = dividend;
    long long dvs = divisor;

    if (dvd < 0) dvd = -dvd;
    if (dvs < 0) dvs = -dvs;

    long long result = 0;

    while (dvd >= dvs)
    {
        long long temp = dvs;
        long long multiple = 1;

        while (dvd >= (temp << 1))
        {
            temp <<= 1;
            multiple <<= 1;
        }

        dvd -= temp;
        result += multiple;
    }

    if ((dividend > 0) ^ (divisor > 0))
        result = -result;

    return (int)result;
}
