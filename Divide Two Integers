#include <limits.h>
#include <stdlib.h>

int divide(int dividend, int divisor) {
    
    if (dividend == INT_MIN && divisor == -1)
        return INT_MAX;

    long dvd = labs(dividend);
    long dvs = labs(divisor);
    int result = 0;

    while (dvd >= dvs) {
        long temp = dvs, multiple = 1;

        while (dvd >= (temp << 1)) {
            temp <<= 1;
            multiple <<= 1;
        }

        dvd -= temp;
        result += multiple;
    }

    if ((dividend > 0) ^ (divisor > 0))
        result = -result;

    return result;
}
