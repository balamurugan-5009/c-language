#include <stdlib.h>
#include <string.h>
char* multiply(char* num1, char* num2) {
    int len1 = strlen(num1);
    int len2 = strlen(num2);
    if (len1 == 0 || len2 == 0) {
        char* zero = malloc(2);
        zero[0] = '0';
        zero[1] = '\0';
        return zero;
    }

    int* result = calloc(len1 + len2, sizeof(int));
    for (int i = len1 - 1; i >= 0; i--) {
        int n1 = num1[i] - '0';
        for (int j = len2 - 1; j >= 0; j--) {
            int n2 = num2[j] - '0';
            result[i + j + 1] += n1 * n2;
        }
    }
    for (int i = len1 + len2 - 1; i > 0; i--) {
        result[i - 1] += result[i] / 10;
        result[i] %= 10;
    }
    int i = 0;
    while (i < len1 + len2 && result[i] == 0) i++;

    if (i == len1 + len2) {
        free(result);
        char* zero = malloc(2);
        zero[0] = '0';
        zero[1] = '\0';
        return zero;
    }
    char* str = malloc(len1 + len2 - i + 1);
    int k = 0;
    for (; i < len1 + len2; i++) {
        str[k++] = result[i] + '0';
    }
    str[k] = '\0';

    free(result);
    return str;
}
